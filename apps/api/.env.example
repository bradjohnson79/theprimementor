DATABASE_URL=postgresql://...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
OPENAI_API_KEY=sk-...
# Divin8 brain policy is centralized in code: chat + reports use GPT-5.1 (no fallback model chain).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=https://theprimementor.com
APP_URL=https://theprimementor.com
ADMIN_URL=https://admin.theprimementor.com
# Local development via Stripe CLI:
# stripe listen --forward-to localhost:3001/api/stripe/webhook
STRIPE_PRICE_FOCUS=price_...
STRIPE_PRICE_MENTORING=price_...
STRIPE_PRICE_REGENERATION=price_...
STRIPE_PRICE_DIVIN8_INTRO_REPORT=price_...
STRIPE_PRICE_DIVIN8_DEEP_DIVE_REPORT=price_...
STRIPE_PRICE_DIVIN8_INITIATE_REPORT=price_...
STRIPE_PRICE_TRAINING_ENTRY=price_...
STRIPE_PRICE_TRAINING_SEEKER=price_...
STRIPE_PRICE_TRAINING_INITIATE=price_...
STRIPE_PRICE_SEEKER_MONTHLY=price_...
STRIPE_PRICE_SEEKER_ANNUAL=price_...
STRIPE_PRICE_INITIATE_MONTHLY=price_...
STRIPE_PRICE_INITIATE_ANNUAL=price_...
# Divin8 one-off reports (Checkout line items — map price IDs only; amounts live in Stripe Dashboard)
STRIPE_PRICE_DIVIN8_INTRO_REPORT=price_...
STRIPE_PRICE_DIVIN8_DEEP_DIVE_REPORT=price_...
STRIPE_PRICE_DIVIN8_INITIATE_REPORT=price_...
PAYMENT_PROVIDER=mock

# Zoom Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Facebook Graph API for public homepage social widget
# Use your Page ID or page username, plus a Page access token with the required Pages API permissions.
FACEBOOK_PAGE_ID=primementorfacebook
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional cache TTL for latest post fetches (milliseconds)
# FACEBOOK_GRAPH_CACHE_TTL_MS=300000

# Contact form delivery
# Option A: full connection URL
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# Option B: host/port credentials
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# Optional sender override
# SMTP_FROM=no-reply@example.com
# Optional explicit admin recipient (falls back to first admin user email)
# ADMIN_EMAIL=admin@example.com

# Booking / calendar scaffolding
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# Physiognomy images: stored locally under apps/api/uploads/physiognomy (gitignored)
# Orphan uploads older than this (ms) are removed periodically (default 48h)
# PHYSIOGNOMY_UPLOAD_MAX_AGE_MS=172800000

# PDF uses Puppeteer + Chromium — use Docker/VPS in production; serverless often needs a worker or external renderer
